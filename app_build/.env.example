# PromptIQ — Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM Configuration (Required for Cognee)
# =============================================================================
LLM_API_KEY=your-openai-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# =============================================================================
# PromptIQ API Security
# =============================================================================
API_KEY=promptiq-dev-key-change-in-production
SECRET_KEY=your-super-secret-jwt-key-change-this

# =============================================================================
# Cognee Configuration
# =============================================================================
COGNEE_DATA_DIR=/app/cognee_data
COGNEE_LOG_LEVEL=INFO

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=PromptIQ
APP_ENV=development
DEBUG=true
HOST=0.0.0.0
PORT=8000

# =============================================================================
# Frontend Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
CORS_ORIGINS=https://promptiq-plum.vercel.app,http://localhost:3000,http://localhost:3001
