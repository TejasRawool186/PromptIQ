# PromptIQ Backend Configuration
# Copy this file to .env and fill in your values

# --- LLM Provider ---
LLM_API_KEY=your-llm-api-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# --- Cognee Configuration ---
COGNEE_LLM_API_KEY=your-llm-api-key-here
COGNEE_LLM_PROVIDER=openai
COGNEE_LLM_MODEL=gpt-4o-mini
COGNEE_VECTOR_DB=lancedb
COGNEE_GRAPH_DB=networkx

# --- API Authentication ---
API_KEY=promptiq-dev-key-change-me
SECRET_KEY=super-secret-jwt-key-change-me-in-production

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Organization ---
DEFAULT_ORG_ID=default_org
DEFAULT_USER_ID=default_user
